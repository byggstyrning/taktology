# =============================================================================
# Building fit-out takt plan — anonymized 3-storey building, 6 takt zones
# GENERATED by scripts/generate_building_demo.py — do not edit by hand.
# Conforms to ontology/takt.ttl v0.5.0. Used by viz/index.html (the 3-layer
# visualizer: plan grid + knowledge graph + 3D building).
#
# A 5-wagon interiors train (framing -> MEP rough-in -> drywall -> MEP
# fixtures -> paint/floor) flows through West+East zones on L1-L3 as a
# flowline: slot(zone p, wagon w) = p + w. Structural slabs + core are
# pre-existing building fabric (bot:Element, no takt task). Element quantities
# / geometry travel as TGraph-style side data (viz/index.html), not core terms.
# =============================================================================

@prefix takt: <https://w3id.org/taktology#> .
@prefix dtc:  <https://dtc-ontology.cms.ed.tum.de/ontology/v2#> .
@prefix bot:  <https://w3id.org/bot#> .
@prefix ex:   <https://w3id.org/taktology/examples/building#> .
@prefix xsd:  <http://www.w3.org/2001/XMLSchema#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

# --- THE PLAN — a takt:TaktGraph (top:KnowledgeGraph + dtc:ConstructionSchedule) ---
ex:plan a takt:TaktGraph ;
    rdfs:label "Building fit-out plan — Project Aspen (anonymized)"@en ;
    takt:taktDuration "P7D"^^xsd:duration ;
    takt:planStart    "2024-09-02"^^xsd:date ;
    dtc:hasProcess ex:task_L1_W_w1 ,
                   ex:task_L1_W_w2 ,
                   ex:task_L1_W_w3 ,
                   ex:task_L1_W_w4 ,
                   ex:task_L1_W_w5 ,
                   ex:task_L1_E_w1 ,
                   ex:task_L1_E_w2 ,
                   ex:task_L1_E_w3 ,
                   ex:task_L1_E_w4 ,
                   ex:task_L1_E_w5 ,
                   ex:task_L2_W_w1 ,
                   ex:task_L2_W_w2 ,
                   ex:task_L2_W_w3 ,
                   ex:task_L2_W_w4 ,
                   ex:task_L2_W_w5 ,
                   ex:task_L2_E_w1 ,
                   ex:task_L2_E_w2 ,
                   ex:task_L2_E_w3 ,
                   ex:task_L2_E_w4 ,
                   ex:task_L2_E_w5 ,
                   ex:task_L3_W_w1 ,
                   ex:task_L3_W_w2 ,
                   ex:task_L3_W_w3 ,
                   ex:task_L3_W_w4 ,
                   ex:task_L3_W_w5 ,
                   ex:task_L3_E_w1 ,
                   ex:task_L3_E_w2 ,
                   ex:task_L3_E_w3 ,
                   ex:task_L3_E_w4 ,
                   ex:task_L3_E_w5 ,
                   ex:task_handover .

# --- The on-site fit-out PROCESS (TBS process axis; Ljung 2026) ---
ex:process_fitout a dtc:Process ;
    rdfs:label "Interior fit-out process"@en .

# --- BUILDING / STOREYS (BOT topology) ---
ex:building a bot:Building ;
    rdfs:label "Project Aspen (anonymized)"@en ;
    bot:hasStorey ex:storey_L1 , ex:storey_L2 , ex:storey_L3 .

ex:storey_L1 a bot:Storey ;
    rdfs:label "Level 1"@en ;
    bot:containsZone ex:zone_L1_W , ex:zone_L1_E ;
    bot:containsElement ex:slab_L1 .
ex:storey_L2 a bot:Storey ;
    rdfs:label "Level 2"@en ;
    bot:containsZone ex:zone_L2_W , ex:zone_L2_E ;
    bot:containsElement ex:slab_L2 .
ex:storey_L3 a bot:Storey ;
    rdfs:label "Level 3"@en ;
    bot:containsZone ex:zone_L3_W , ex:zone_L3_E ;
    bot:containsElement ex:slab_L3 .

# Structural fabric carried in the graph (pre-existing shell; no takt task).
ex:slab_L1 a bot:Element ; rdfs:label "Floor slab, Level 1"@en .
ex:slab_L2 a bot:Element ; rdfs:label "Floor slab, Level 2"@en .
ex:slab_L3 a bot:Element ; rdfs:label "Floor slab, Level 3"@en .
ex:core a bot:Element ; rdfs:label "Structural core (stairs + shafts)"@en .

# --- TAKT ZONES + their trade operands (bot:containsElement) ---
ex:zone_L1_W a takt:TaktZone ;
    rdfs:label "L1 West (Z1)" ;
    bot:adjacentZone ex:zone_L1_E ;
    bot:containsElement ex:part_L1_W ,
                        ex:duct_L1_W ,
                        ex:board_L1_W ,
                        ex:fixture_L1_W ,
                        ex:finish_L1_W ,
                        ex:slab_L1 ,
                        ex:core .
ex:zone_L1_E a takt:TaktZone ;
    rdfs:label "L1 East (Z2)" ;
    bot:adjacentZone ex:zone_L2_W ;
    bot:containsElement ex:part_L1_E ,
                        ex:duct_L1_E ,
                        ex:board_L1_E ,
                        ex:fixture_L1_E ,
                        ex:finish_L1_E ,
                        ex:slab_L1 ,
                        ex:core .
ex:zone_L2_W a takt:TaktZone ;
    rdfs:label "L2 West (Z3)" ;
    bot:adjacentZone ex:zone_L2_E ;
    bot:containsElement ex:part_L2_W ,
                        ex:duct_L2_W ,
                        ex:board_L2_W ,
                        ex:fixture_L2_W ,
                        ex:finish_L2_W ,
                        ex:slab_L2 ,
                        ex:core .
ex:zone_L2_E a takt:TaktZone ;
    rdfs:label "L2 East (Z4)" ;
    bot:adjacentZone ex:zone_L3_W ;
    bot:containsElement ex:part_L2_E ,
                        ex:duct_L2_E ,
                        ex:board_L2_E ,
                        ex:fixture_L2_E ,
                        ex:finish_L2_E ,
                        ex:slab_L2 ,
                        ex:core .
ex:zone_L3_W a takt:TaktZone ;
    rdfs:label "L3 West (Z5)" ;
    bot:adjacentZone ex:zone_L3_E ;
    bot:containsElement ex:part_L3_W ,
                        ex:duct_L3_W ,
                        ex:board_L3_W ,
                        ex:fixture_L3_W ,
                        ex:finish_L3_W ,
                        ex:slab_L3 ,
                        ex:core .
ex:zone_L3_E a takt:TaktZone ;
    rdfs:label "L3 East (Z6)" ;
    bot:containsElement ex:part_L3_E ,
                        ex:duct_L3_E ,
                        ex:board_L3_E ,
                        ex:fixture_L3_E ,
                        ex:finish_L3_E ,
                        ex:slab_L3 ,
                        ex:core .

ex:part_L1_W a bot:Element ; rdfs:label "Stud partitions, L1 West"@en .
ex:duct_L1_W a bot:Element ; rdfs:label "Duct & conduit run, L1 West"@en .
ex:board_L1_W a bot:Element ; rdfs:label "Drywall boarding, L1 West"@en .
ex:fixture_L1_W a bot:Element ; rdfs:label "MEP fixtures, L1 West"@en .
ex:finish_L1_W a bot:Element ; rdfs:label "Paint & floor finish, L1 West"@en .
ex:part_L1_E a bot:Element ; rdfs:label "Stud partitions, L1 East"@en .
ex:duct_L1_E a bot:Element ; rdfs:label "Duct & conduit run, L1 East"@en .
ex:board_L1_E a bot:Element ; rdfs:label "Drywall boarding, L1 East"@en .
ex:fixture_L1_E a bot:Element ; rdfs:label "MEP fixtures, L1 East"@en .
ex:finish_L1_E a bot:Element ; rdfs:label "Paint & floor finish, L1 East"@en .
ex:part_L2_W a bot:Element ; rdfs:label "Stud partitions, L2 West"@en .
ex:duct_L2_W a bot:Element ; rdfs:label "Duct & conduit run, L2 West"@en .
ex:board_L2_W a bot:Element ; rdfs:label "Drywall boarding, L2 West"@en .
