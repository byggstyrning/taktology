ex:duct_L2_E a bot:Element ; rdfs:label "Duct & conduit run, L2 East"@en .
ex:board_L2_E a bot:Element ; rdfs:label "Drywall boarding, L2 East"@en .
ex:fixture_L2_E a bot:Element ; rdfs:label "MEP fixtures, L2 East"@en .
