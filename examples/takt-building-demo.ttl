ex:part_L3_W a bot:Element ; rdfs:label "Stud partitions, L3 West"@en .
ex:duct_L3_W a bot:Element ; rdfs:label "Duct & conduit run, L3 West"@en .
ex:board_L3_W a bot:Element ; rdfs:label "Drywall boarding, L3 West"@en .
ex:fixture_L3_W a bot:Element ; rdfs:label "MEP fixtures, L3 West"@en .
