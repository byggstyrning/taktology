    takt:actsOn       ex:part_L1_W ;
    takt:performedBy  ex:crew_1 ;
    takt:partOfProcess ex:process_fitout ;
    takt:slot         1 ;
    takt:hasSuccessorSameZone  ex:task_L1_W_w2 ;
    takt:hasSuccessorSameWagon ex:task_L1_E_w1 .

