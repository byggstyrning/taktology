ex:finish_L3_E a bot:Element ; rdfs:label "Paint & floor finish, L3 East"@en .

# --- WAGON TYPES (the train's consist) + planned crews ---
ex:wagon_1 a takt:WagonType ;
    rdfs:label "1 · Framing — metal stud partitions"@en ;
    takt:trade "framing" .
ex:wagon_2 a takt:WagonType ;
    rdfs:label "2 · MEP rough-in — ducts & conduit"@en ;
    takt:trade "mep-rough" .
ex:wagon_3 a takt:WagonType ;
    rdfs:label "3 · Drywall boarding"@en ;
    takt:trade "drywall" .
ex:wagon_4 a takt:WagonType ;
    rdfs:label "4 · MEP fixtures & terminals"@en ;
    takt:trade "mep-fix" .
ex:wagon_5 a takt:WagonType ;
    rdfs:label "5 · Paint & flooring"@en ;
    takt:trade "finish" .

ex:crew_1 a takt:Crew ; rdfs:label "SUB-01" .
ex:crew_2 a takt:Crew ; rdfs:label "SUB-02" .
ex:crew_3 a takt:Crew ; rdfs:label "SUB-03" .
ex:crew_4 a takt:Crew ; rdfs:label "SUB-04" .
ex:crew_5 a takt:Crew ; rdfs:label "SUB-05" .

# =============================================================================
# THE GRID — 6 zones x 5 wagons = 30 cells, flowline slot = position + wagon
