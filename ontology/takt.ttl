# =============================================================================
# Taktology — a minimal, research-grounded vocabulary for takt production planning
# =============================================================================
#
# v0.3.0 — MINIMAL CORE, aligned to the Digital Twin Construction (DTC) ontology.
#
# What this is
#   The canonical takt skeleton: 5 classes, 6 object properties, 6 datatype
#   properties (17 terms). It adds ONLY what existing ontologies lack — the takt
#   type-layer (wagon), the takt rhythm, and work-density effort values — and
#   reuses the DTC ontology for the process / zone / resource backbone.
#
# How it composes (alignment by REFERENCE, not owl:imports — keeps it lightweight)
#   dtc:  Digital Twin Construction ontology  -> rdfs:subClassOf / subPropertyOf
#         (the process, working-zone and resource backbone; DTC itself imports BOT)
#   ifc:  IFC 4.3 process schema              -> skos:closeMatch (interchange anchor)
#   top:  TopologicPy                          -> rdfs:seeAlso (geometry/quantity engine)
#   Every term carries dcterms:source -> the research corpus that grounds it.
#
# Why DTC reuse (resolves research/decisions/ADR-001's open reuse-vs-mint question)
#   DTC already models the construction process (Process > WorkPackage/Activity/Task),
#   working zones (AsPlannedWorkingZone), worker crews (AsPlannedWorkerCrew), the
#   task->element target (hasTarget) and task->zone location (isPerformedIn). Takt
#   only needs to specialize these and add the takt-specific values. Schlenger &
#   Borrmann (2024), the schedule<->IFC linking method, builds on DTC — so aligning
#   to DTC aligns to that work too.
#
# Honest scope notes
#   - DTC reifies sequencing (ProcessPrecondition + requiresProcess + hasSequenceType)
#     and resource assignment (hasResourceAssignment + requiresResource). Takt uses
#     simpler DIRECT edges (hasSuccessor, performedBy); these are rdfs:seeAlso-related
#     to DTC, not subproperties, because the shapes differ. Noted per term.
#   - DTC has no task TYPE layer; takt:WagonType fills that gap (closeMatch
#     ifc:IfcTaskType only).
#   - DTC terms below were read from the published ontology TTL (base
#     https://dtc-ontology.cms.ed.tum.de/ontology#); a v2 exists — verify before
#     pinning a version.
#
# License: CC BY 4.0 (see LICENSE).
# =============================================================================

@prefix takt:    <https://w3id.org/taktology#> .
@prefix dtc:     <https://dtc-ontology.cms.ed.tum.de/ontology#> .
@prefix top:     <https://wassimj.github.io/topologicpy/ontology/topologicpy#> .
@prefix bot:     <https://w3id.org/bot#> .
@prefix ifc:     <https://standards.buildingsmart.org/IFC/DEV/IFC4/ADD2_TC1/OWL#> .
@prefix owl:     <http://www.w3.org/2002/07/owl#> .
@prefix rdf:     <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs:    <http://www.w3.org/2000/01/rdf-schema#> .
@prefix skos:    <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd:     <http://www.w3.org/2001/XMLSchema#> .
@prefix dcterms: <http://purl.org/dc/terms/> .

# -----------------------------------------------------------------------------
<https://w3id.org/taktology> a owl:Ontology ;
    dcterms:title "Taktology — takt production planning vocabulary (minimal core)"@en ;
    dcterms:license <https://creativecommons.org/licenses/by/4.0/> ;
    owl:versionInfo "0.3.0" ;
    rdfs:comment """Minimal core takt-planning vocabulary. Specializes the Digital
        Twin Construction (DTC) ontology for takt and adds the takt-specific
        type-layer, rhythm and work-density values. Aligned to IFC 4.3 by
        skos:closeMatch; TopologicPy supplies geometry/quantities. Alignment is by
        reference (no owl:imports) to stay lightweight."""@en ;
    rdfs:seeAlso <https://dtc-ontology.cms.ed.tum.de/ontology/> ;
    rdfs:seeAlso <https://ceur-ws.org/Vol-3824/paper3.pdf> ;
    rdfs:seeAlso <https://wassimj.github.io/topologicpy/ontology/topologicpy.ttl> .

# =============================================================================
# CLASSES (5)
# =============================================================================

takt:TaktZone a owl:Class ;
    rdfs:subClassOf dtc:AsPlannedWorkingZone ;
    rdfs:label "Takt zone"@en ;
    rdfs:comment """A spatial work area through which takt wagons flow at a fixed
        rhythm — often a half-floor, fire compartment or room cluster (macro/normal/
        micro per the three-level method). A specialization of DTC's planned working
        zone; DTC zones reach BOT and can carry geometry, and TopologicPy computes
        the zone's area/volume (top:area / top:volume)."""@en ;
    skos:closeMatch ifc:IfcSpatialZone ;
    rdfs:seeAlso top:FunctionalZone ;
    dcterms:source <https://iglc.net/Papers/Details/1350> ,   # dlouhy-2016-three-level
                   <https://iglc.net/Papers/Details/902> .    # frandson-2013-cladding

takt:WagonType a owl:Class ;
    rdfs:label "Wagon type"@en ;
    rdfs:comment """The reusable definition of one trade's work package — e.g.
        'Enkling gipsväggar', crew 5, 0.58 h/m². The TYPE level; its per-zone
        occurrences are takt:TaktTask, linked by takt:instantiates. DTC has no task
        type layer, so this term has no DTC parent and aligns only to IFC's type
        mechanism."""@en ;
    skos:closeMatch ifc:IfcTaskType ;
    rdfs:seeAlso dtc:Activity ;   # DTC's 'planned production method steps' (instance-level)
    dcterms:source <https://doi.org/10.1002/bate.202200088> ,                      # becker-tschickardt-2023-bimtakt (activity structure)
                   <https://doi.org/10.1061/(ASCE)CO.1943-7862.0002398> .          # tommelein-2022-wdm (work density)

takt:TaktTask a owl:Class ;
    rdfs:subClassOf dtc:WorkPackage ;
    rdfs:label "Takt task"@en ;
    rdfs:comment """One occurrence: one wagon performed in one takt zone for one takt
        (one coloured cell of the plan). A DTC WorkPackage is 'planned multi-element
        construction' — which a takt task is, since it covers all of one trade's
        elements in a zone. Carries its own takt time and acts on a trade-specific
        subset of the zone's elements."""@en ;
    skos:closeMatch ifc:IfcTask ;
    dcterms:source <https://doi.org/10.1002/bate.202200088> .   # becker-tschickardt-2023-bimtakt

takt:Crew a owl:Class ;
    rdfs:subClassOf dtc:AsPlannedWorkerCrew ;
    rdfs:label "Crew"@en ;
    rdfs:comment "A planned worker crew (gang) that performs takt tasks; the Dexx codes in a takt plan."@en ;
    skos:closeMatch ifc:IfcCrewResource ;
    dcterms:source <https://doi.org/10.1002/bate.202200088> .   # becker-tschickardt-2023-bimtakt (MA/Kol)

takt:TaktTime a owl:Class ;
    rdfs:label "Takt time"@en ;
    rdfs:comment """The schedule payload of a takt task: the fixed takt (taktDuration)
        and the takt slot it occupies. DTC has no task-time class (it puts
        dtc:startTime / dtc:endTime directly on a Process), so this aligns to IFC's
        IfcTaskTime; reuse dtc:startTime/endTime for actual calendar dates."""@en ;
    skos:closeMatch ifc:IfcTaskTime ;
    rdfs:seeAlso dtc:startTime , dtc:endTime ;
    dcterms:source <https://iglc.net/Papers/Details/1297> ,    # haghsheno-2016-history (takt = fixed rhythm)
                   <https://doi.org/10.24928/2017/0297> .       # binninger-2017-technical-takt

# =============================================================================
# OBJECT PROPERTIES (6)
# =============================================================================

takt:instantiates a owl:ObjectProperty ;
    rdfs:label "instantiates"@en ;
    rdfs:comment """Links a takt task occurrence to the wagon type it realises. No
        clean DTC equivalent (DTC has no type layer); compare dtc:hasActivity
        (WorkPackage->Activity), which is method-of, not type-of."""@en ;
    rdfs:domain takt:TaktTask ;
    rdfs:range  takt:WagonType ;
    skos:closeMatch ifc:IfcRelDefinesByType ;
    rdfs:seeAlso dtc:hasActivity ;
    dcterms:source <https://standards.buildingsmart.org/IFC/DEV/IFC4/ADD2_TC1/OWL/index.html> .

takt:performedIn a owl:ObjectProperty ;
    rdfs:subPropertyOf dtc:isPerformedIn ;
    rdfs:label "performed in"@en ;
    rdfs:comment """The takt zone a task is located in — the work AREA, which generally
        contains elements for several trades, not only this task's. For the operand,
        use takt:actsOn. Specializes dtc:isPerformedIn (WorkPackage->WorkingZone)."""@en ;
    rdfs:domain takt:TaktTask ;
    rdfs:range  takt:TaktZone ;
    skos:closeMatch ifc:IfcRelAssignsToProduct ;
    dcterms:source <https://iglc.net/Papers/Details/1181> .   # frandson-2015-lbms-vs-takt (space as resource)

takt:actsOn a owl:ObjectProperty ;
    rdfs:subPropertyOf dtc:hasTarget ;
    rdfs:label "acts on"@en ;
    rdfs:comment """The building element(s) this task constructs, installs or operates
        on — the OPERAND, distinct from the zone it sits in (takt:performedIn). A
        trade-specific SUBSET of the zone's contents; it — not the zone total — is
        what the quantity->duration formula sums over (a zone is assigned to one trade
        per takt, per the Work Density Method). Specializes dtc:hasTarget (Task/Action
        -> building element). Broader than IFC's 'resulting product': covers produced
        AND operated-on elements."""@en ;
    rdfs:domain takt:TaktTask ;
    skos:closeMatch ifc:IfcRelAssignsToProduct ;
    dcterms:source <https://doi.org/10.1061/(ASCE)CO.1943-7862.0002398> .   # tommelein-2022-wdm

takt:performedBy a owl:ObjectProperty ;
    rdfs:label "performed by"@en ;
    rdfs:comment """The crew that performs the takt task. DTC reifies this
        (Activity/Task hasResourceAssignment -> assignment requiresResource -> resource);
        takt uses a direct edge for simplicity, related to that pattern by seeAlso."""@en ;
    rdfs:domain takt:TaktTask ;
    rdfs:range  takt:Crew ;
    skos:closeMatch ifc:IfcRelAssignsToProcess ;
    rdfs:seeAlso dtc:hasResourceAssignment , dtc:requiresResource ;
    dcterms:source <https://doi.org/10.1002/bate.202200088> .   # becker-tschickardt-2023-bimtakt

takt:hasSuccessor a owl:ObjectProperty ;
    rdfs:label "has successor"@en ;
    rdfs:comment """The next takt task in execution order. The CHAIN of these edges is
        the TRAIN — a train is a path through the task graph, not a class. DTC reifies
        sequencing (Process hasPrecondition -> ProcessPrecondition requiresProcess +
        hasSequenceType {EndStart,...}); takt uses a direct edge (default finish-start),
        related by seeAlso. Reading A (cross-trade convoy through a zone) is the
        default; for Reading B (one wagon across zones) place these edges between
        same-wagon occurrences in adjacent zones."""@en ;
    rdfs:domain takt:TaktTask ;
    rdfs:range  takt:TaktTask ;
    skos:closeMatch ifc:IfcRelSequence ;
    rdfs:seeAlso dtc:requiresProcess ;
    dcterms:source <https://doi.org/10.1061/9780784413517.168> ,   # frandson-2014-crc (predecessor field)
                   <https://doi.org/10.1080/01446193.2020.1824295> .   # lehtovaara-2021 (location vs trade flow)

takt:hasTaktTime a owl:ObjectProperty ;
    rdfs:label "has takt time"@en ;
    rdfs:comment "Links a takt task to its TaktTime payload. Takt-specific (DTC carries timing directly on the process)."@en ;
    rdfs:domain takt:TaktTask ;
    rdfs:range  takt:TaktTime ;
    dcterms:source <https://iglc.net/Papers/Details/1297> .   # haghsheno-2016-history

# =============================================================================
# DATATYPE PROPERTIES (6) — the takt-specific values DTC does not carry
# =============================================================================

takt:productionRate a owl:DatatypeProperty ;
    rdfs:label "production rate"@en ;
    rdfs:comment "Effort / work-density value in person-hours per unit, e.g. h/m² (BIMTakt; Work Density Method). No DTC equivalent."@en ;
    rdfs:domain takt:WagonType ;
    rdfs:range  xsd:decimal ;
    dcterms:source <https://doi.org/10.1002/bate.202200088> ,                      # becker-tschickardt-2023-bimtakt (h/m²)
                   <https://doi.org/10.1061/(ASCE)CO.1943-7862.0002398> .          # tommelein-2022-wdm (work density)

takt:crewSize a owl:DatatypeProperty ;
    rdfs:label "crew size"@en ;
    rdfs:comment "Number of workers per column (MA/Kol). Compare dtc:quantity on a resource."@en ;
    rdfs:domain takt:WagonType ;
    rdfs:range  xsd:integer ;
    rdfs:seeAlso dtc:quantity ;
    dcterms:source <https://doi.org/10.1002/bate.202200088> .   # becker-tschickardt-2023-bimtakt

takt:quantityUnit a owl:DatatypeProperty ;
    rdfs:label "quantity unit"@en ;
    rdfs:comment "What the wagon's quantity is measured in: AREA | VOLUME | COUNT. Selects which geometric quantity (e.g. top:area vs top:volume) the duration formula reads — a 2D activity over area, a 3D one over volume."@en ;
    rdfs:domain takt:WagonType ;
    rdfs:range  xsd:string ;
    dcterms:source <https://doi.org/10.1002/bate.202200088> .   # becker-tschickardt-2023-bimtakt (2D/3D formula)

takt:taktDuration a owl:DatatypeProperty ;
    rdfs:label "takt duration"@en ;
    rdfs:comment "The fixed takt — the rhythm each wagon occupies in a zone — as an ISO 8601 duration, e.g. 'P1W'. This is the BEAT, distinct from a task's computed work content (which must fit within it)."@en ;
    rdfs:domain takt:TaktTime ;
    rdfs:range  xsd:duration ;
    dcterms:source <https://iglc.net/Papers/Details/1297> ,    # haghsheno-2016-history (takt = fixed unit of time)
                   <https://doi.org/10.24928/2017/0297> .       # binninger-2017-technical-takt

takt:slot a owl:DatatypeProperty ;
    rdfs:label "takt slot"@en ;
    rdfs:comment "The takt slot the task occupies (e.g. week / takt index in the plan grid)."@en ;
    rdfs:domain takt:TaktTime ;
    rdfs:range  xsd:integer ;
    dcterms:source <https://doi.org/10.1002/bate.202200088> .   # becker-tschickardt-2023-bimtakt (the grid)

takt:isMilestone a owl:DatatypeProperty ;
    rdfs:label "is milestone"@en ;
    rdfs:comment "TRUE for milestone tasks (e.g. 'Inflytt', 'Dem. bygghiss'). Mirrors IfcTask.IsMilestone."@en ;
    rdfs:domain takt:TaktTask ;
    rdfs:range  xsd:boolean ;
    dcterms:source <https://standards.buildingsmart.org/IFC/DEV/IFC4/ADD2_TC1/OWL/index.html> .

# =============================================================================
# IMPLEMENTER NOTES
# =============================================================================
# 1. ALIGNMENT BY REFERENCE. This file does not owl:imports DTC/IFC/top: — it only
#    references their IRIs (keeps it lightweight, per ADR-3). Load DTC when you want
#    a reasoner to use its axioms.
#
# 2. DURATION IS COMPUTED. taktDuration is the fixed beat; a task's required work
#    content is derived and checked to fit:
#       qty   = sum( e.area  for e in task.actsOn )       # or e.volume, per quantityUnit
#       hours = qty * wagonType.productionRate
#       days  = hours / (wagonType.crewSize * HOURS_PER_DAY)   # must fit within taktDuration
#    Read the quantity from takt:actsOn (the trade operand), NOT the zone total.
#
# 3. THE TRAIN is the takt:hasSuccessor chain (a path), not a class — dropped from
#    v0.2.0 deliberately. Query it as a path; bundle with a SKOS collection or a DTC
#    construct if you need to name one.
#
# 4. NAMESPACES TO VERIFY before publishing: the w3id.org/taktology redirect (not yet
#    registered); the exact top: URI against the TopologicPy ttl; and the DTC version
#    (a v2 exists at .../ontology/v2/).
#
# 5. closeMatch != equivalentClass. Do not strengthen any skos:closeMatch without
#    verifying identical cardinality/semantics. performedIn and actsOn both closeMatch
#    IfcRelAssignsToProduct on purpose (IFC overloads it for location vs operand).
# =============================================================================
